# Exemplo de configuração Nginx para o Hayusten Finance no VPS.
# Coloca este ficheiro em: /etc/nginx/sites-available/hayusten
# Activar: ln -s /etc/nginx/sites-available/hayusten /etc/nginx/sites-enabled/

# Frontend de assinantes — app.hayusten.com (ou domínio principal)
server {
    listen 80;
    server_name app.hayusten.com;
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    server_name app.hayusten.com;

    # SSL gerido pelo Cloudflare — usa certificado origin.
    ssl_certificate /etc/ssl/cloudflare/hayusten.crt;
    ssl_certificate_key /etc/ssl/cloudflare/hayusten.key;

    # Headers de segurança (complementam o Helmet do Express).
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Servir o frontend React (SPA).
    root /var/www/hayusten/frontend-assinantes/dist;
    index index.html;

    # Para SPA — React Router gere as rotas no cliente.
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Proxy para a API backend.
    location /api/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;

        # Timeout generoso para uploads e exportações.
        proxy_read_timeout 60s;
    }

    # Compressão para assets estáticos.
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml;
    gzip_min_length 1000;
}

# Frontend admin — admin.hayusten.com
server {
    listen 443 ssl http2;
    server_name admin.hayusten.com;

    ssl_certificate /etc/ssl/cloudflare/hayusten-admin.crt;
    ssl_certificate_key /etc/ssl/cloudflare/hayusten-admin.key;

    # Restringir acesso ao painel admin por IP (equipa interna).
    # Descomenta e ajusta os IPs da equipa:
    # allow 197.218.x.x;
    # deny all;

    root /var/www/hayusten/frontend-admin/dist;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /admin/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
