# =============================================================================
# HAYUSTEN FINANCE — VARIÁVEIS DE AMBIENTE
# Copiar para .env e preencher com valores reais
# =============================================================================

# --- APLICAÇÃO ---
NODE_ENV=development
PORT=3000
# URL base do frontend (para links nos emails)
FRONTEND_URL=http://localhost:5173
# URL base do admin (painel interno)
ADMIN_URL=http://localhost:5174
# URL base do backend (para callbacks de pagamento)
API_URL=http://localhost:3000

# --- BASE DE DADOS (MySQL 8+) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=hayusten
DB_PASSWORD=password_segura_aqui
DB_NAME=hayusten_finance
# Tamanho máximo do pool de conexões
DB_POOL_MAX=10

# --- REDIS ---
# Usar instâncias separadas por db-index para isolar cache, sessões e filas
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB_CACHE=0
REDIS_DB_SESSOES=1
REDIS_DB_FILAS=2

# --- JWT ---
# Segredo mínimo 64 caracteres. Gerar com: openssl rand -base64 64
JWT_SECRET=coloca_aqui_segredo_muito_longo_e_aleatorio_minimo_64_chars
# Duração do access token (curto por segurança)
JWT_EXPIRACAO=15m
# Duração do refresh token no Redis (em dias)
REFRESH_TOKEN_EXPIRACAO_DIAS=7

# --- STRIPE ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLIC_KEY=pk_test_...
# Segredo do webhook Stripe (gerado no dashboard Stripe)
STRIPE_WEBHOOK_SECRET=whsec_...
# ID do preço no Stripe para o plano premium
STRIPE_PRECO_PREMIUM=price_...

# --- M-PESA (Vodacom Moçambique) ---
MPESA_API_KEY=
MPESA_PUBLIC_KEY=
MPESA_SERVICE_PROVIDER_CODE=
MPESA_BASE_URL=https://api.sandbox.vm.co.mz
# URL que a M-Pesa chama após pagamento
MPESA_CALLBACK_URL=https://api.hayusten.com/pagamentos/mpesa/callback

# --- EMOLA (Emtel Moçambique) ---
EMOLA_API_KEY=
EMOLA_API_SECRET=
EMOLA_MERCHANT_CODE=
EMOLA_BASE_URL=https://api.emola.co.mz
EMOLA_CALLBACK_URL=https://api.hayusten.com/pagamentos/emola/callback

# --- EMAIL (SMTP) ---
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_SEGURO=false
EMAIL_UTILIZADOR=apikey
EMAIL_PASSWORD=SG_...
EMAIL_REMETENTE=Hayusten Finance <noreply@hayusten.com>

# --- SENTRY (monitorização de erros em produção) ---
SENTRY_DSN=https://...@sentry.io/...

# --- ANTHROPIC (IA) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODELO=claude-opus-4-5

# --- CORS ---
# Origens permitidas separadas por vírgula
CORS_ORIGENS=http://localhost:5173,https://app.hayusten.com
