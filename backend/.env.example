# =============================================================================
# HAYUSTEN FINANCE — VARIÁVEIS DE AMBIENTE
# Copiar para .env e preencher todos os valores antes de arrancar o servidor.
# NUNCA commitar o ficheiro .env — está no .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# BASE DE DADOS (MySQL 8+)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hayusten_finance
DB_USER=hayusten_user
DB_PASSWORD=

# Pool de conexões — ajustar conforme carga esperada no VPS
DB_POOL_MIN=2
DB_POOL_MAX=10

# -----------------------------------------------------------------------------
# REDIS (cache, sessões e filas BullMQ — partilham o mesmo servidor mas DBs separados)
# -----------------------------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# DB 0 → cache geral
REDIS_DB_CACHE=0
# DB 1 → sessões e refresh tokens
REDIS_DB_SESSOES=1
# DB 2 → filas BullMQ
REDIS_DB_FILAS=2

# -----------------------------------------------------------------------------
# AUTENTICAÇÃO JWT
# Gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# -----------------------------------------------------------------------------
JWT_SECRET=
JWT_EXPIRACAO=15m
REFRESH_TOKEN_EXPIRACAO_DIAS=7

# -----------------------------------------------------------------------------
# STRIPE (pagamentos internacionais com cartão)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# ID do produto/preço para o plano premium no dashboard Stripe
STRIPE_PRECO_PREMIUM=price_...

# -----------------------------------------------------------------------------
# M-PESA (Vodacom Moçambique — pagamentos mobile money)
# -----------------------------------------------------------------------------
MPESA_API_KEY=
MPESA_PUBLIC_KEY=
MPESA_SERVICE_PROVIDER_CODE=
# URL pública onde o M-Pesa envia o callback após pagamento
MPESA_CALLBACK_URL=https://api.hayusten.co.mz/pagamentos/mpesa/callback

# -----------------------------------------------------------------------------
# EMOLA (Movitel Moçambique — pagamentos mobile money)
# -----------------------------------------------------------------------------
EMOLA_API_KEY=
EMOLA_API_SECRET=
EMOLA_MERCHANT_CODE=
# URL pública onde o Emola envia o callback após pagamento
EMOLA_CALLBACK_URL=https://api.hayusten.co.mz/pagamentos/emola/callback

# -----------------------------------------------------------------------------
# EMAIL (Nodemailer — SMTP transaccional)
# Recomendado: Brevo (ex-Sendinblue) ou Mailgun para produção
# -----------------------------------------------------------------------------
EMAIL_HOST=smtp.brevo.com
EMAIL_PORT=587
EMAIL_SEGURO=false
EMAIL_UTILIZADOR=
EMAIL_PASSWORD=
EMAIL_REMETENTE_NOME=Hayusten Finance
EMAIL_REMETENTE=noreply@hayusten.co.mz

# -----------------------------------------------------------------------------
# ANTHROPIC / CLAUDE (funcionalidades de IA)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
# Modelo a usar — claude-sonnet-4-5 para produção (melhor custo/benefício)
CLAUDE_MODELO=claude-sonnet-4-5

# -----------------------------------------------------------------------------
# SENTRY (monitorização de erros em produção)
# -----------------------------------------------------------------------------
SENTRY_DSN=

# -----------------------------------------------------------------------------
# APLICAÇÃO
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3000

# URL do frontend dos assinantes (usado em CORS e links de email)
FRONTEND_URL=https://app.hayusten.co.mz

# URL do painel de administração (usado em CORS)
ADMIN_URL=https://admin.hayusten.co.mz

# URL da API pública (usada nos links de email)
API_URL=https://api.hayusten.co.mz
